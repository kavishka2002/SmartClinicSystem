# SmartClinic Environment Configuration
# This file serves as a template for local environment setup
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local or any credentials to Git!

########################
# FIREBASE CONFIGURATION
########################

# Firebase Client SDK Configuration (NEXT_PUBLIC = exposed to browser, safe to expose)
# Get these values from: https://console.firebase.google.com → Project Settings → General
NEXT_PUBLIC_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=YOUR_FIREBASE_AUTH_DOMAIN
NEXT_PUBLIC_FIREBASE_PROJECT_ID=smart-clinic-system-abb66
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=YOUR_FIREBASE_STORAGE_BUCKET
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=YOUR_FIREBASE_MESSAGING_SENDER_ID
NEXT_PUBLIC_FIREBASE_APP_ID=YOUR_FIREBASE_APP_ID
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=YOUR_FIREBASE_MEASUREMENT_ID

# Firebase Admin SDK Configuration (Server-side ONLY - NOT exposed to browser)
# This should be a path to your firebase-admin-service-account.json file
FIREBASE_ADMIN_CREDENTIALS_PATH=firebase-admin-service-account.json

# Alternative: Set this if you want to use the full JSON as a string (not recommended)
# FIREBASE_ADMIN_CREDENTIALS={"type":"service_account","project_id":"...",...}

########################
# APPLICATION SETTINGS
########################
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Session/Cookie Configuration
SESSION_COOKIE_NAME=smartclinic_session
# Recommended: Use a strong random string for production
# Example: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your-very-long-and-random-secret-key-here

########################
# OPTIONAL: API KEYS & TOKENS
########################
# Add any third-party API keys here
# Example:
# STRIPE_PUBLIC_KEY=pk_live_...
# STRIPE_SECRET_KEY=sk_live_...
# TWILIO_ACCOUNT_SID=...
# TWILIO_AUTH_TOKEN=...

########################
# VERCEL DEPLOYMENT (Production)
########################
# When deploying to Vercel, set these variables in Vercel dashboard:
# - All NEXT_PUBLIC_* variables (same as above)
# - FIREBASE_ADMIN_CREDENTIALS_PATH or FIREBASE_ADMIN_CREDENTIALS
# - NODE_ENV=production
# - SESSION_SECRET (generate a new one)
